############################################################
# Hawk Vision – Self-hosted Supabase environment
# Copy to .env and fill in your values.
# Generated keys via:  node generate-keys.mjs
############################################################

# ── PostgreSQL ────────────────────────────────────────────
# Your PostgreSQL superuser password.
# URLENCODED version: replace special chars (* → %2A, # → %23, etc.)
POSTGRES_PASSWORD='CHANGE_ME'
POSTGRES_PASSWORD_URLENCODED='CHANGE_ME'
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ── JWT / Auth keys ──────────────────────────────────────
# Run: node generate-keys.mjs   to auto-generate these ↓
JWT_SECRET=
JWT_EXPIRY=3600
ANON_KEY=
SERVICE_ROLE_KEY=

# ── URLs ─────────────────────────────────────────────────
# Your public domain (with https after setting up SSL)
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:8000

# ── Kong API gateway ports ───────────────────────────────
API_PORT=8000
API_SSL_PORT=8443

# ── Signup ───────────────────────────────────────────────
DISABLE_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true

# ── SMTP (optional – needed for password reset emails) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@example.com
ADDITIONAL_REDIRECT_URLS=
