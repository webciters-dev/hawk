# ─── Hawk Vision Strategies – Frontend Environment ───────────
# Copy to .env.production (or .env.local for dev) and fill in values.
#
# For self-hosted setup, VITE_SUPABASE_URL is your domain
# (same origin — nginx proxies /rest/v1, /auth/v1, /storage/v1 to Kong).

VITE_SUPABASE_URL=https://your-domain.com
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
